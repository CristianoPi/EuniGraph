EUNIGRAPH_APP_NAME=EuniGraph
EUNIGRAPH_ENV=development
EUNIGRAPH_LOG_LEVEL=INFO
EUNIGRAPH_API_V1_PREFIX=/api/v1
EUNIGRAPH_DOCS_ENABLED=true

POSTGRES_DB=eunigraph
POSTGRES_USER=eunigraph
POSTGRES_PASSWORD=eunigraph
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

EUNIGRAPH_DATABASE_URL=postgresql+psycopg://eunigraph:eunigraph@postgres:5432/eunigraph

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PUBLICATIONS=publication_embeddings

BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=/api/backend

OPENAIRE_BEGINNERS_KIT_PATH=./data/openaire/beginners_kit
EUNIGRAPH_COAUTHORSHIP_GRAPH_STORAGE_PATH=./data/graphs/coauthorship
EUNIGRAPH_SEMANTIC_GRAPH_STORAGE_PATH=./data/graphs/semantic

# Gemini
GEMINI_API_KEY=
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDINGS_VERSION=v1

# Embeddings pipeline
EMBEDDINGS_ENABLED=true
EMBEDDINGS_BATCH_SIZE=16
EMBEDDINGS_REQUEST_TIMEOUT_SECONDS=60
EMBEDDINGS_MAX_RETRIES=3
EMBEDDINGS_CONTENT_FIELDS=title,authors,abstract
